---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contacto — CONSTRU" description="Contáctanos para cotizar tu proyecto industrial. Asesoría especializada en galpones, obras civiles, urbanizaciones y edificios corporativos.">
  <!-- Hero Section for Contact -->
  <section class="relative w-full h-[409px] md:h-[512px] flex items-center justify-center border-b border-surface-container-high">
    <div class="absolute inset-0 bg-cover bg-center opacity-30 mix-blend-overlay"
      style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuDemAqqPUzb0NgmTpnX3bxlZXqWbeoPlwESdeLLTEvLuiGarYlmhRRVrWDlAgwnxcz9YP0Y1GjMzCKPxDpTcXR327j2j5GJNuJZGGeK-VEth4h_iRuViZidnbzq9EWORuKnbvazaya_Ws1CgX0i09cBq18qo02__75T-OEToy9LSYQXcsqT9AeElLuvay77EixHB9-BaOpF5Xizxe-WTmM6fp2M47yhDDQXFob2lkKjKP8MupY_OFiIxTki92j6LXV2-NSxkfVawg')">
    </div>
    <div class="relative z-10 text-center px-gutter max-w-container-max mx-auto">
      <h1 class="font-display-lg text-display-lg-mobile md:text-display-lg uppercase text-on-background mb-4">
        Contacto
      </h1>
      <p class="font-body-lg text-body-lg text-on-surface-variant max-w-2xl mx-auto">
        Inicia tu proyecto con expertos. Estamos listos para asesorarte en cada etapa de tu desarrollo industrial.
      </p>
    </div>
  </section>

  <!-- Contact Grid -->
  <section class="py-margin-mobile md:py-margin-desktop px-gutter max-w-container-max mx-auto">
    <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 md:gap-16">
      <!-- Contact Info Panel -->
      <div class="lg:col-span-5 flex flex-col space-y-12">
        <div>
          <h2 class="font-headline-lg text-headline-lg uppercase text-on-background mb-8 border-b-2 border-primary-container pb-2 inline-block">
            Detalles de Contacto
          </h2>
          <div class="space-y-8">
            <div class="flex items-start space-x-4">
              <div class="bg-surface-container p-3 rounded-none border border-surface-container-highest">
                <span class="material-symbols-outlined text-primary-container text-3xl">location_on</span>
              </div>
              <div>
                <h3 class="font-label-lg text-label-lg uppercase tracking-widest text-on-surface mb-1">
                  Dirección Central
                </h3>
                <p class="font-body-md text-body-md text-on-surface-variant">
                  Antonio Varas 303, Oficina 713<br />Providencia, Santiago, Chile
                </p>
              </div>
            </div>
            <div class="flex items-start space-x-4">
              <div class="bg-surface-container p-3 rounded-none border border-surface-container-highest">
                <span class="material-symbols-outlined text-primary-container text-3xl">phone_enabled</span>
              </div>
              <div>
                <h3 class="font-label-lg text-label-lg uppercase tracking-widest text-on-surface mb-1">
                  Teléfono Directo
                </h3>
                <p class="font-body-md text-body-md text-on-surface-variant">+56 9 7212 8015</p>
              </div>
            </div>
            <div class="flex items-start space-x-4">
              <div class="bg-surface-container p-3 rounded-none border border-surface-container-highest">
                <span class="material-symbols-outlined text-primary-container text-3xl">mail</span>
              </div>
              <div>
                <h3 class="font-label-lg text-label-lg uppercase tracking-widest text-on-surface mb-1">
                  Correo Electrónico
                </h3>
                <p class="font-body-md text-body-md text-on-surface-variant">contacto@constru.cl</p>
              </div>
            </div>
          </div>
        </div>
        <!-- Map Placeholder -->
        <div class="h-64 w-full bg-surface-container-low border border-surface-container-highest relative overflow-hidden group">
          <div class="w-full h-full bg-surface-container-lowest flex items-center justify-center">
            <span class="material-symbols-outlined text-surface-container-highest text-6xl">map</span>
            <span class="absolute bottom-4 left-4 font-label-sm text-label-sm uppercase text-on-surface-variant">SANTIAGO, CL</span>
          </div>
          <div class="absolute inset-0 border-2 border-transparent group-hover:border-primary-container transition-colors duration-300 pointer-events-none"></div>
        </div>
      </div>
      <!-- Contact Form -->
      <div class="lg:col-span-7 bg-surface-container-low p-6 md:p-10 border border-surface-container-highest">
        <h2 class="font-headline-md text-headline-md uppercase text-on-background mb-6">Cotiza tu Proyecto</h2>
        <form class="space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div class="flex flex-col">
              <label class="font-label-sm text-label-sm uppercase text-on-surface-variant mb-2" for="name">Nombre Completo</label>
              <input
                class="bg-transparent border border-surface-container-highest text-on-background p-3 focus:border-primary-container focus:ring-0 transition-colors rounded-none font-body-md"
                id="name" placeholder="Ej. Juan Pérez" type="text" />
            </div>
            <div class="flex flex-col">
              <label class="font-label-sm text-label-sm uppercase text-on-surface-variant mb-2" for="email">Correo Electrónico</label>
              <input
                class="bg-transparent border border-surface-container-highest text-on-background p-3 focus:border-primary-container focus:ring-0 transition-colors rounded-none font-body-md"
                id="email" placeholder="juan@empresa.com" type="email" />
            </div>
          </div>
          <div class="flex flex-col">
            <label class="font-label-sm text-label-sm uppercase text-on-surface-variant mb-2" for="project_type">Tipo de Proyecto</label>
            <select
              class="bg-surface-container-low border border-surface-container-highest text-on-background p-3 focus:border-primary-container focus:ring-0 transition-colors rounded-none font-body-md appearance-none"
              id="project_type">
              <option disabled selected value="">Selecciona un área</option>
              <option value="galpones">Galpones Industriales</option>
              <option value="obras_civiles">Obras Civiles</option>
              <option value="urbanizaciones">Urbanizaciones</option>
              <option value="edificios">Edificios Corporativos</option>
              <option value="altillos">Altillos Estructurales</option>
            </select>
          </div>
          <div class="flex flex-col">
            <label class="font-label-sm text-label-sm uppercase text-on-surface-variant mb-2" for="message">Mensaje o Detalles del Proyecto</label>
            <textarea
              class="bg-transparent border border-surface-container-highest text-on-background p-3 focus:border-primary-container focus:ring-0 transition-colors rounded-none font-body-md resize-none"
              id="message"
              placeholder="Describe brevemente los requerimientos técnicos o plazos de tu proyecto..."
              rows="5"></textarea>
          </div>
          <button
            class="w-full bg-primary-container text-on-primary-container font-label-lg text-label-lg uppercase font-bold py-4 tracking-widest hover:bg-primary-fixed active:translate-y-[1px] transition-all duration-150 rounded-none mt-4 flex justify-center items-center gap-2"
            type="button">
            <span>Enviar Solicitud</span>
            <span class="material-symbols-outlined text-lg">arrow_forward</span>
          </button>
        </form>
      </div>
    </div>
  </section>
</Layout>
