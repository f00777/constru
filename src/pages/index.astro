---
import Layout from '../layouts/Layout.astro';
import { Image } from 'astro:assets';
---

<Layout>
  <!-- Hero Section -->
  <header class="relative min-h-[90vh] flex items-center pt-24 pb-20">
    <div class="absolute inset-0 z-0">
      <div class="absolute inset-0 bg-background/80 mix-blend-multiply z-10"></div>
      <Image alt="Hero background" class="w-full h-full object-cover" inferSize={true} loading="eager" fetchpriority="high"
        src="https://lh3.googleusercontent.com/aida-public/AB6AXuB9nC7sDpHvGVP--_pnk-V_onbYwnofYysK9YwdXVf4nprs3P4HhaR00wZH2lbimqKPsiA0pdZXjWLjNw5LAfiNle941Du-KFD61NTa4ZAZ44zaqN0MSYeIQ9fuCNu60TlYbkFNHjKhhbH2suZmDCIBzHRrIf6Ox3fUuTnck9ewjZKfNvzmTCbTLUMuv8kNCsAjKinuHGZ6g4ejYY1NyhianfKn9Ns2uGkCg7ndIdxN3nBJWUPmNLJeNnSUr6keCeJvmy17UF-8OA" />
    </div>
    <div class="relative z-10 w-full max-w-container-max mx-auto px-gutter grid grid-cols-1 md:grid-cols-12 gap-gutter">
      <div class="md:col-span-8 flex flex-col items-start gap-6">
        <p class="text-primary font-label-lg text-label-lg tracking-widest uppercase border-l-2 border-primary pl-4">
          Proyectos Industriales · Estructuras Metálicas · Diseño
        </p>
        <h1 class="font-display-lg-mobile md:font-display-lg text-display-lg-mobile md:text-display-lg uppercase text-on-background">
          INGENIERÍA Y<br />
          <span class="text-primary-container">CONSTRUCCIÓN</span><br />
          DE ALTO NIVEL
        </h1>
        <p class="font-body-lg text-body-lg text-on-surface-variant max-w-2xl mt-4">
          Diseño y construcción integrados bajo una sola dirección. Del proyecto al llaves en mano, con
          control total de calidad y plazos.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 mt-8">
          <a href="/contacto"
            class="bg-primary-container text-on-primary-container px-8 py-4 font-label-lg text-label-lg uppercase font-bold tracking-widest hover:bg-primary transition-colors active:translate-y-[1px]">
            Cotizar Proyecto
          </a>
          <a href="/portafolio"
            class="border-2 border-on-background text-on-background px-8 py-4 font-label-lg text-label-lg uppercase font-bold tracking-widest hover:bg-on-background hover:text-background transition-colors active:translate-y-[1px]">
            Ver Portafolio
          </a>
        </div>
      </div>
    </div>
  </header>

  <!-- Stats Section -->
  <section class="bg-surface-container-lowest py-16 border-y border-surface-container-highest relative z-20">
    <div class="max-w-container-max mx-auto px-gutter">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 md:gap-gutter divide-x divide-surface-container-highest">
        <div class="flex flex-col items-center justify-center text-center p-4">
          <span class="font-headline-xl text-headline-xl text-primary-container mb-2">+20</span>
          <span class="font-label-lg text-label-lg uppercase tracking-widest text-on-surface-variant">Años de<br />Experiencia</span>
        </div>
        <div class="flex flex-col items-center justify-center text-center p-4">
          <span class="font-headline-xl text-headline-xl text-primary-container mb-2">+100</span>
          <span class="font-label-lg text-label-lg uppercase tracking-widest text-on-surface-variant">Obras<br />Ejecutadas</span>
        </div>
        <div class="flex flex-col items-center justify-center text-center p-4">
          <span class="font-headline-xl text-headline-xl text-primary-container mb-2">+200.000</span>
          <span class="font-label-lg text-label-lg uppercase tracking-widest text-on-surface-variant">M² Construidos</span>
        </div>
        <div class="flex flex-col items-center justify-center text-center p-4">
          <span class="font-headline-xl text-headline-xl text-primary-container mb-2">CHILE</span>
          <span class="font-label-lg text-label-lg uppercase tracking-widest text-on-surface-variant">Cobertura<br />Nacional</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Specialties Grid -->
  <section class="w-full bg-surface">
    <div class="py-margin-mobile md:py-margin-desktop px-gutter max-w-container-max mx-auto">
      <div class="flex justify-between items-end mb-12 border-b-2 border-surface-container-highest pb-4">
        <h2 class="font-headline-lg text-headline-lg uppercase text-white">Nuestras Especialidades</h2>
        <a class="hidden md:flex items-center gap-2 font-label-lg text-label-lg text-primary hover:text-primary-fixed transition-colors uppercase tracking-widest group"
          href="/servicios">
          Ver todos los servicios
          <span class="material-symbols-outlined text-[18px] group-hover:translate-x-1 transition-transform">arrow_forward</span>
        </a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
        <!-- Card 1 -->
        <div class="bg-surface-container-high p-8 border-t-4 border-primary-container hover:bg-surface-container-highest transition-colors group relative overflow-hidden flex flex-col h-full">
          <span class="material-symbols-outlined text-[40px] text-primary mb-6 font-light">factory</span>
          <h3 class="font-headline-md text-headline-md text-on-surface mb-4 uppercase">Galpones y Naves Industriales</h3>
          <p class="font-body-md text-body-md text-on-surface-variant mb-8 flex-grow">Estructuras metálicas para bodegaje y producción a gran escala con altos estándares de seguridad.</p>
          <a class="font-label-lg text-label-lg text-primary uppercase tracking-widest flex items-center gap-2 mt-auto" href="/servicios">
            Ver Detalles
            <span class="material-symbols-outlined text-[16px] group-hover:translate-x-1 transition-transform">arrow_forward</span>
          </a>
        </div>
        <!-- Card 2 -->
        <div class="bg-surface-container-high p-8 border-t-4 border-primary-container hover:bg-surface-container-highest transition-colors group relative overflow-hidden flex flex-col h-full">
          <span class="material-symbols-outlined text-[40px] text-primary mb-6 font-light">foundation</span>
          <h3 class="font-headline-md text-headline-md text-on-surface mb-4 uppercase">Obras Civiles</h3>
          <p class="font-body-md text-body-md text-on-surface-variant mb-8 flex-grow">Fundaciones, radiers y pavimentos industriales diseñados para soportar cargas pesadas y uso continuo.</p>
          <a class="font-label-lg text-label-lg text-primary uppercase tracking-widest flex items-center gap-2 mt-auto" href="/servicios">
            Ver Detalles
            <span class="material-symbols-outlined text-[16px] group-hover:translate-x-1 transition-transform">arrow_forward</span>
          </a>
        </div>
        <!-- Card 3 -->
        <div class="bg-surface-container-high p-8 border-t-4 border-primary-container hover:bg-surface-container-highest transition-colors group relative overflow-hidden flex flex-col h-full">
          <span class="material-symbols-outlined text-[40px] text-primary mb-6 font-light">architecture</span>
          <h3 class="font-headline-md text-headline-md text-on-surface mb-4 uppercase">Urbanizaciones</h3>
          <p class="font-body-md text-body-md text-on-surface-variant mb-8 flex-grow">Redes de agua potable, alcantarillado, pavimentación y veredas para complejos industriales.</p>
          <a class="font-label-lg text-label-lg text-primary uppercase tracking-widest flex items-center gap-2 mt-auto" href="/servicios">
            Ver Detalles
            <span class="material-symbols-outlined text-[16px] group-hover:translate-x-1 transition-transform">arrow_forward</span>
          </a>
        </div>
        <!-- Card 4 -->
        <div class="bg-surface-container-high p-8 border-t-4 border-primary-container hover:bg-surface-container-highest transition-colors group relative overflow-hidden flex flex-col h-full">
          <span class="material-symbols-outlined text-[40px] text-primary mb-6 font-light">apartment</span>
          <h3 class="font-headline-md text-headline-md text-on-surface mb-4 uppercase">Edificios Corporativos</h3>
          <p class="font-body-md text-body-md text-on-surface-variant mb-8 flex-grow">Arquitectura funcional con alta terminación para oficinas administrativas integradas a plantas.</p>
          <a class="font-label-lg text-label-lg text-primary uppercase tracking-widest flex items-center gap-2 mt-auto" href="/servicios">
            Ver Detalles
            <span class="material-symbols-outlined text-[16px] group-hover:translate-x-1 transition-transform">arrow_forward</span>
          </a>
        </div>
      </div>
      <div class="mt-8 text-center md:hidden">
        <a class="inline-flex items-center gap-2 font-label-lg text-label-lg text-primary uppercase tracking-widest border border-primary px-6 py-3"
          href="/servicios">
          Ver todos los servicios
        </a>
      </div>
    </div>
  </section>

  <!-- Why Choose Us Section -->
  <section class="bg-surface-container-lowest py-margin-mobile md:py-margin-desktop border-y border-surface-container-highest relative overflow-hidden">
    <div class="max-w-container-max mx-auto px-gutter grid grid-cols-1 md:grid-cols-2 gap-12 items-center relative z-10">
      <div>
        <h2 class="font-headline-lg text-headline-lg uppercase text-on-background mb-4">Por Qué Elegir <span class="text-primary-container">CONSTRU</span></h2>
        <p class="font-body-lg text-body-lg text-on-surface-variant mb-8 border-l-4 border-primary-container pl-4">
          Dirigida por un equipo multidisciplinario de expertos, CONSTRU integra el diseño arquitectónico con
          la ejecución constructiva, garantizando que la visión original se materialice con exactitud técnica,
          control de costos y calidad estructural.
        </p>
        <ul class="space-y-6">
          <li class="flex items-start gap-4">
            <span class="material-symbols-outlined text-primary-container text-[24px] filled-icon shrink-0">check_circle</span>
            <div>
              <h4 class="font-label-lg text-label-lg uppercase tracking-wider text-on-surface mb-1">Integración Arquitectura + Construcción</h4>
              <p class="font-body-md text-body-md text-on-surface-variant">Un solo interlocutor para todo el proceso, reduciendo tiempos y errores de comunicación.</p>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <span class="material-symbols-outlined text-primary-container text-[24px] filled-icon shrink-0">check_circle</span>
            <div>
              <h4 class="font-label-lg text-label-lg uppercase tracking-wider text-on-surface mb-1">Especialistas en estructuras metálicas</h4>
              <p class="font-body-md text-body-md text-on-surface-variant">Fabricación e instalación precisa bajo estrictas normativas de seguridad y sismorresistencia.</p>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <span class="material-symbols-outlined text-primary-container text-[24px] filled-icon shrink-0">check_circle</span>
            <div>
              <h4 class="font-label-lg text-label-lg uppercase tracking-wider text-on-surface mb-1">Cumplimiento estricto de plazos</h4>
              <p class="font-body-md text-body-md text-on-surface-variant">Planificación detallada y ejecución eficiente para minimizar el tiempo de inactividad de su negocio.</p>
            </div>
          </li>
        </ul>
        <a href="/nosotros"
          class="mt-10 inline-block border-2 border-primary-container text-primary-container px-8 py-4 font-label-lg text-label-lg uppercase font-bold tracking-widest hover:bg-primary-container hover:text-on-primary-container transition-colors active:translate-y-[1px]">
          Conocer la empresa
        </a>
      </div>
      <div class="relative h-[400px] md:h-[600px] border border-surface-container-highest bg-surface p-2">
        <div class="bg-cover bg-center w-full h-full grayscale hover:grayscale-0 transition-all duration-700"
          style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuBzcuZ46ywV6rQQKBkO-bLq38O9S6-3hpk4MhjcJafswk3U5KgyYXS2ZEh380uVt8YMzaKKHzFHU8iiPI4g5KJgdDZIvnO8TfYg3oPO8IuC2YKmEPLyMquASQIs9U9UPcT9U_QVH8sRZ2TcmTxr7lHYZagRHJXFOQ9_Qps5m6n8JJN_Cr-CTdDTl7J6F_vfs3JWxXWlnHsiwHw9_TzoGdMae84XDYo7nwNwX9kxWWILY3WxxpNGYQJQyBNcCoQkRbNtOANF4p9yTg')">
        </div>
        <div class="absolute top-0 left-0 w-4 h-4 border-t-2 border-l-2 border-primary-container"></div>
        <div class="absolute top-0 right-0 w-4 h-4 border-t-2 border-r-2 border-primary-container"></div>
        <div class="absolute bottom-0 left-0 w-4 h-4 border-b-2 border-l-2 border-primary-container"></div>
        <div class="absolute bottom-0 right-0 w-4 h-4 border-b-2 border-r-2 border-primary-container"></div>
      </div>
    </div>
  </section>

  <!-- Featured Works -->
  <section class="w-full bg-surface">
    <div class="py-margin-mobile md:py-margin-desktop px-gutter max-w-container-max mx-auto">
      <div class="text-center mb-12">
        <h2 class="font-headline-lg text-headline-lg uppercase mb-4 text-white">Obras Destacadas</h2>
        <div class="w-16 h-1 bg-primary-container mx-auto mb-6"></div>
        <p class="font-body-md text-body-md text-on-surface-variant max-w-2xl mx-auto">
          Nuestra experiencia materializada en proyectos industriales a lo largo del país. Soluciones robustas para desafíos complejos.
        </p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <!-- Project 1 -->
        <a class="group relative aspect-video overflow-hidden bg-surface-container-high block" href="/portafolio">
          <div class="absolute inset-0 bg-cover bg-center grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700"
            style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuDKM7UXJnUzhbosQC5v0wBMi3IZYH6NKID9gJi_Q0yo3EVXjkLONF4JFD7q0wALmHbKCt_QbDYptZddkCyTuN4GwVwAr0okJG_4AgVSGMowyKkvTtofPDsnkYWjkUO4DhZWSYGopeeBTky_PctQ0_SemaaGxqgYlcVEMCy2IMaH_kWkeyA0xOynEGd5MvX_O1tHOqA53tAZPIO7ooX4TOSBV3rqEc9DLhWd2c22hl8_SlvRZNush1dRCssX3gf7ZmOz4mWCGio_dQ')">
          </div>
          <div class="absolute inset-0 bg-gradient-to-t from-background via-background/50 to-transparent opacity-80 group-hover:opacity-90 transition-opacity"></div>
          <div class="absolute inset-0 bg-primary-container/90 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
            <span class="font-label-lg text-label-lg uppercase text-on-primary-container border-2 border-on-primary-container px-6 py-2">Ver Proyecto</span>
          </div>
          <div class="absolute bottom-0 left-0 p-6 w-full z-10 pointer-events-none transition-transform duration-300 group-hover:translate-y-4 group-hover:opacity-0">
            <span class="font-label-sm text-label-sm uppercase text-primary-container tracking-widest mb-2 block">Galpón</span>
            <h3 class="font-headline-md text-headline-md uppercase mb-1 text-white">Bodega Viña Undurraga</h3>
            <p class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">Viña Undurraga <span class="mx-2">•</span> 2022</p>
          </div>
        </a>
        <!-- Project 2 -->
        <a class="group relative aspect-video overflow-hidden bg-surface-container-high block" href="/portafolio">
          <div class="absolute inset-0 bg-cover bg-center grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700"
            style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuAWSpxEziWwILAWSv7_a7J-zy5tE3_GQlp-lOOnt2n2yXJGnvwl67-m5XZ04RWU6FDVCprIDBNuOgkSBQF1-T52z0MfMskqJuJJvKUbZ54TF5dF-Adje4H_wbV0UAfWtQr4PPp1PK5daT-SY4olkkYRS-YDOGepawElUGJ_8mzDmRIv85969hJ4dBylbXl0808SGDcZvsVmuNAxaP8i01hx7ot8LBipCHPPWP8KyIF89FD2E46Vo98n-sQcQg2AlDWoH2UJFc8zkw')">
          </div>
          <div class="absolute inset-0 bg-gradient-to-t from-background via-background/50 to-transparent opacity-80 group-hover:opacity-90 transition-opacity"></div>
          <div class="absolute inset-0 bg-primary-container/90 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
            <span class="font-label-lg text-label-lg uppercase text-on-primary-container border-2 border-on-primary-container px-6 py-2">Ver Proyecto</span>
          </div>
          <div class="absolute bottom-0 left-0 p-6 w-full z-10 pointer-events-none transition-transform duration-300 group-hover:translate-y-4 group-hover:opacity-0">
            <span class="font-label-sm text-label-sm uppercase text-primary-container tracking-widest mb-2 block">Especial</span>
            <h3 class="font-headline-md text-headline-md uppercase mb-1 text-white">Hyundai Padel Center</h3>
            <p class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">Hyundai Padel Center <span class="mx-2">•</span> 2021</p>
          </div>
        </a>
        <!-- Project 3 -->
        <a class="group relative aspect-video overflow-hidden bg-surface-container-high block" href="/portafolio">
          <div class="absolute inset-0 bg-cover bg-center grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700"
            style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuDCAsnozjZHuG1f4lq85VEED5JLKsryMBPG55IC6CEOSiidbKCOuZTjAZ7H8FlVKNNAaIbg_nNVrPVO86cXbO9p_ogUbqTaNEJj01-i-n_JIS_5hZK5keNrLXcRG1kT0U1VzkYb1lS2a4VTCW8gdSYkmDWXYuc3Nu5m0eR8ZJ0eUS3k1SaDn_idTyd3gm5FNvXOup9H31t5MEgmqfU9_BR3MtnIaMGev4OJ6K91ijDUTnKjT9cm8xz4pjmDbL3Fu7OxTLR2Bmc_4g')">
          </div>
          <div class="absolute inset-0 bg-gradient-to-t from-background via-background/50 to-transparent opacity-80 group-hover:opacity-90 transition-opacity"></div>
          <div class="absolute inset-0 bg-primary-container/90 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
            <span class="font-label-lg text-label-lg uppercase text-on-primary-container border-2 border-on-primary-container px-6 py-2">Ver Proyecto</span>
          </div>
          <div class="absolute bottom-0 left-0 p-6 w-full z-10 pointer-events-none transition-transform duration-300 group-hover:translate-y-4 group-hover:opacity-0">
            <span class="font-label-sm text-label-sm uppercase text-primary-container tracking-widest mb-2 block">Logístico</span>
            <h3 class="font-headline-md text-headline-md uppercase mb-1 text-white">Centro Distribución Kori Wasi</h3>
            <p class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">Kori Wasi <span class="mx-2">•</span> 2013</p>
          </div>
        </a>
        <!-- Project 4 -->
        <a class="group relative aspect-video overflow-hidden bg-surface-container-high block" href="/portafolio">
          <div class="absolute inset-0 bg-cover bg-center grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700"
            style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuCyvA70XH-P-rZgFSUYi-CbhjKGpgI2Y9rXqitqQqkVujxxO4vzfDw9PRjAWzwmYBCMKElnSzo2M0FgbNaYMQWxecWjCPGHvLaQhvPc09dCcBOu5wjuZzQdY5pOgCCKpXeS_K9yA49mtNYrZx-Z1Zh2vc7ojOreZ-fzNvocz_qPbBg1cBC1HgJ9WrzHp3qEU3ucrzsYi8-FQ_rWm_ZR5-d16yH3pz3arhJA7VVQz98NVJdkU6M8KUJQOo6zhqRzHSDBHsvhRgOugw')">
          </div>
          <div class="absolute inset-0 bg-gradient-to-t from-background via-background/50 to-transparent opacity-80 group-hover:opacity-90 transition-opacity"></div>
          <div class="absolute inset-0 bg-primary-container/90 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
            <span class="font-label-lg text-label-lg uppercase text-on-primary-container border-2 border-on-primary-container px-6 py-2">Ver Proyecto</span>
          </div>
          <div class="absolute bottom-0 left-0 p-6 w-full z-10 pointer-events-none transition-transform duration-300 group-hover:translate-y-4 group-hover:opacity-0">
            <span class="font-label-sm text-label-sm uppercase text-primary-container tracking-widest mb-2 block">Frigorífico</span>
            <h3 class="font-headline-md text-headline-md uppercase mb-1 text-white">Frigorífico Preferred Freezer</h3>
            <p class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">Preferred Freezer <span class="mx-2">•</span> 2008</p>
          </div>
        </a>
      </div>
      <div class="mt-12 text-center">
        <a href="/portafolio"
          class="border-2 px-8 py-4 font-label-lg text-label-lg uppercase font-bold tracking-widest hover:text-background transition-colors active:translate-y-[1px] border-white text-white hover:bg-white inline-block">
          Explorar todo el portafolio
        </a>
      </div>
    </div>
  </section>
</Layout>
