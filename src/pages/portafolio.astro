---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Portafolio — CONSTRU" description="Portafolio de obras industriales, comerciales y civiles ejecutadas por CONSTRU a lo largo de Chile.">
  <!-- Page Header -->
  <section class="py-margin-desktop px-gutter bg-surface-container-low border-b border-surface-variant">
    <div class="max-w-container-max mx-auto text-center">
      <h1 class="font-display-lg text-display-lg-mobile md:text-display-lg text-on-surface uppercase mb-4">
        Portafolio de Obras
      </h1>
      <p class="font-body-lg text-body-lg text-on-surface-variant max-w-2xl mx-auto">
        Nuestra experiencia materializada en proyectos industriales, comerciales y civiles de alta complejidad a lo largo del país.
      </p>
    </div>
  </section>

  <!-- Main Content -->
  <section class="py-margin-desktop px-gutter">
    <div class="max-w-container-max mx-auto">
      <!-- Filters -->
      <div class="flex flex-wrap justify-center gap-4 mb-16">
        <button class="filter-btn active border-2 border-outline text-on-surface px-8 py-3 font-label-lg text-label-lg uppercase font-bold hover:border-primary-container hover:text-primary-container transition-colors">
          Todos
        </button>
        <button class="filter-btn border-2 border-outline text-on-surface px-8 py-3 font-label-lg text-label-lg uppercase font-bold hover:border-primary-container hover:text-primary-container transition-colors">
          Industrial
        </button>
        <button class="filter-btn border-2 border-outline text-on-surface px-8 py-3 font-label-lg text-label-lg uppercase font-bold hover:border-primary-container hover:text-primary-container transition-colors">
          Comercial
        </button>
        <button class="filter-btn border-2 border-outline text-on-surface px-8 py-3 font-label-lg text-label-lg uppercase font-bold hover:border-primary-container hover:text-primary-container transition-colors">
          Obra Civil
        </button>
      </div>

      <!-- Portfolio Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <!-- Project 1 -->
        <a class="group relative aspect-video overflow-hidden bg-surface-container-high block" href="#">
          <div class="absolute inset-0 bg-cover bg-center grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700"
            style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuCqwFGqovTkVmPLq59Q0FlHbWNys4gcd_j3-4FCGAJrm6AtkTyGGZV4TDPwmncL5bMGd-5BwRbpd7V9hjGOVTVe7dm5TzV1QZwfqXhKyQBbPT2R3C6NKj2f2MvbmUVufnBKYACQPmg_R1fHQzjNDio9QaZ62iAdGlp8PorD6WPUNxozFBaVv1-aB4bteStwVLxmvXctxmFcMMyuTZpg2hdg9HpgXL5aOIrW1WGkJb0nL-DzGEifr1Gy_3VN-cwQQAjidY2wbW3Niw')">
          </div>
          <div class="absolute inset-0 bg-gradient-to-t from-background via-background/50 to-transparent opacity-80 group-hover:opacity-90 transition-opacity"></div>
          <div class="absolute inset-0 bg-primary-container/90 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
            <span class="font-label-lg text-label-lg uppercase text-on-primary-container border-2 border-on-primary-container px-6 py-2">Ver Proyecto</span>
          </div>
          <div class="absolute bottom-0 left-0 p-6 w-full z-10 pointer-events-none transition-transform duration-300 group-hover:translate-y-4 group-hover:opacity-0">
            <span class="font-label-sm text-label-sm uppercase text-primary-container tracking-widest mb-2 block">Industrial</span>
            <h3 class="font-headline-md text-headline-md uppercase mb-1 text-white">Galpón Bodega Viña Undurraga</h3>
            <p class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">Viña Undurraga <span class="mx-2">•</span> 2022</p>
          </div>
        </a>

        <!-- Project 2 -->
        <a class="group relative aspect-video overflow-hidden bg-surface-container-high block" href="#">
          <div class="absolute inset-0 bg-cover bg-center grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700"
            style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuA4R9MbfnuLmTvIsx2tKBzCtT2oH1PBRnkZDcZiKWoiK642Me4h-NTwfYBmtCPsIHcP-3XXYijOeOVwKOBw85xxS0miPjO9BiTiSe2tUlfxRcLmRsK1MckSjI_G-OEGrwRJxQf_zYSROTLvoZOy_rXuxurlcLs0UQSEkDeF0tx2-HlQmLHgpnAs9OTWDYsD1wbAXzPpcCAQ-5-hKhCXO2lnrdAu65ylVGRbf8s6_t8b2yPZhUR5hn9-Vd15No5hVsz_PLc_U1ZhBg')">
          </div>
          <div class="absolute inset-0 bg-gradient-to-t from-background via-background/50 to-transparent opacity-80 group-hover:opacity-90 transition-opacity"></div>
          <div class="absolute inset-0 bg-primary-container/90 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
            <span class="font-label-lg text-label-lg uppercase text-on-primary-container border-2 border-on-primary-container px-6 py-2">Ver Proyecto</span>
          </div>
          <div class="absolute bottom-0 left-0 p-6 w-full z-10 pointer-events-none transition-transform duration-300 group-hover:translate-y-4 group-hover:opacity-0">
            <span class="font-label-sm text-label-sm uppercase text-primary-container tracking-widest mb-2 block">Comercial</span>
            <h3 class="font-headline-md text-headline-md uppercase mb-1 text-white">Hyundai Padel Center</h3>
            <p class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">Santiago <span class="mx-2">•</span> 2021</p>
          </div>
        </a>

        <!-- Project 3 -->
        <a class="group relative aspect-video overflow-hidden bg-surface-container-high block" href="#">
          <div class="absolute inset-0 bg-cover bg-center grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700"
            style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuBjIRFNHYDwRr5GD2LcmjiT8bLOWqZa9mrT3vl96hAiZYCdnmjQVVfvlo0d1x47tvLvqlLCXyJV5f6nhTqOCGgIXS0LSzDuD0mUVhz6uptcdIrCWcKuBNbCu6QshiQJBasatWgzu6U07Hh4ACP1r2R3CoqV_Rl8bbXQQQqGWKa9GzkfbU5krOBktP1YMc1xBaWHocG7_GcEbKl3GsHnTDqDDBUBnJ7mljDa5MskfJhHuBtGY05DMbg8Tc8fIWssC6UYFZ94P7Qshw')">
          </div>
          <div class="absolute inset-0 bg-gradient-to-t from-background via-background/50 to-transparent opacity-80 group-hover:opacity-90 transition-opacity"></div>
          <div class="absolute inset-0 bg-primary-container/90 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
            <span class="font-label-lg text-label-lg uppercase text-on-primary-container border-2 border-on-primary-container px-6 py-2">Ver Proyecto</span>
          </div>
          <div class="absolute bottom-0 left-0 p-6 w-full z-10 pointer-events-none transition-transform duration-300 group-hover:translate-y-4 group-hover:opacity-0">
            <span class="font-label-sm text-label-sm uppercase text-primary-container tracking-widest mb-2 block">Industrial</span>
            <h3 class="font-headline-md text-headline-md uppercase mb-1 text-white">Sto Chile Galpón y Oficinas</h3>
            <p class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">Lampa <span class="mx-2">•</span> 2019</p>
          </div>
        </a>

        <!-- Project 4 -->
        <a class="group relative aspect-video overflow-hidden bg-surface-container-high block" href="#">
          <div class="absolute inset-0 bg-cover bg-center grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700"
            style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuDUXe82X9nGGSuwrdGlqQqcTJdemsCUi8QdCvYeprD1_U9ALxvwGvAaUl8ktuu1ASe4Egmn_iZpe1h3m6_n2Qj2dj0Hjd3oH8UQ5bGmwseCz69CgnMEZ-IVfX-Q8CaXzaMFKIY1WFwsKwCFHE8Jf2VtIBpD1B9W_Uk-sEkiE8bEggUxjhDAVux-sYD4gcN24SdrtsmMXHGgNg3SnKOvI5hFs9xvTcbEqfBDpoIuS9x3WRWj8u5wLqFlyLjh3GJjWu-oUBSrDgK2iA')">
          </div>
          <div class="absolute inset-0 bg-gradient-to-t from-background via-background/50 to-transparent opacity-80 group-hover:opacity-90 transition-opacity"></div>
          <div class="absolute inset-0 bg-primary-container/90 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
            <span class="font-label-lg text-label-lg uppercase text-on-primary-container border-2 border-on-primary-container px-6 py-2">Ver Proyecto</span>
          </div>
          <div class="absolute bottom-0 left-0 p-6 w-full z-10 pointer-events-none transition-transform duration-300 group-hover:translate-y-4 group-hover:opacity-0">
            <span class="font-label-sm text-label-sm uppercase text-primary-container tracking-widest mb-2 block">Logístico</span>
            <h3 class="font-headline-md text-headline-md uppercase mb-1 text-white">Oficinas y Centro Distribución Kori Wasi</h3>
            <p class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">Quilicura <span class="mx-2">•</span> 2013</p>
          </div>
        </a>

        <!-- Project 5 -->
        <a class="group relative aspect-video overflow-hidden bg-surface-container-high block" href="#">
          <div class="absolute inset-0 bg-cover bg-center grayscale group-hover:grayscale-0 group-hover:scale-105 transition-all duration-700"
            style="background-image: url('https://lh3.googleusercontent.com/aida-public/AB6AXuADKA6LUYysfnVv7Ocu19YmC3_1bs-VgpGZOptAsVL--GXt-DePtv9k3JPQsj2QN_dLXQWAwqdTgtKhaNy5XaLmP-N3Vq6VpUXLsmbCeIvotSFa6CZHXNJ-ni5jPBWDHJfOlP_Cl6ja0UN01fHTjkK1dmg7CP8_HcsggPg_erJRb44iN5Kpx-dvJcZs7gsi66PSF8LDyIW0tdLWAOorXs2K3XIkIjeCqOIVn1MKRLUSedIR0iYrt60bVLJ7a8571FKi2WBQz9CseA')">
          </div>
          <div class="absolute inset-0 bg-gradient-to-t from-background via-background/50 to-transparent opacity-80 group-hover:opacity-90 transition-opacity"></div>
          <div class="absolute inset-0 bg-primary-container/90 opacity-0 group-hover:opacity-100 transition-opacity duration-300 flex items-center justify-center">
            <span class="font-label-lg text-label-lg uppercase text-on-primary-container border-2 border-on-primary-container px-6 py-2">Ver Proyecto</span>
          </div>
          <div class="absolute bottom-0 left-0 p-6 w-full z-10 pointer-events-none transition-transform duration-300 group-hover:translate-y-4 group-hover:opacity-0">
            <span class="font-label-sm text-label-sm uppercase text-primary-container tracking-widest mb-2 block">Frigorífico</span>
            <h3 class="font-headline-md text-headline-md uppercase mb-1 text-white">Frigorífico Preferred Freezer</h3>
            <p class="font-label-sm text-label-sm text-on-surface-variant uppercase tracking-wider">San Bernardo <span class="mx-2">•</span> 2008</p>
          </div>
        </a>

        <!-- Project 6 (CTA) -->
        <a class="group relative aspect-video overflow-hidden bg-surface-container-highest block flex items-center justify-center" href="/contacto">
          <div class="flex flex-col items-center justify-center text-center p-8 z-10">
            <h3 class="font-headline-lg text-headline-lg uppercase text-on-surface mb-6">¿Listo para construir?</h3>
            <span class="bg-primary-container text-on-primary-container px-8 py-4 font-label-lg text-label-lg uppercase font-bold hover:bg-primary-fixed transition-colors active:translate-y-[1px]">
              Cotizar Proyecto
            </span>
          </div>
        </a>
      </div>

      <div class="mt-12 text-center">
        <button class="border-2 border-outline text-on-surface px-8 py-4 font-label-lg text-label-lg uppercase font-bold hover:bg-surface-variant transition-colors inline-flex items-center gap-2">
          Cargar Más Proyectos
          <span class="material-symbols-outlined">expand_more</span>
        </button>
      </div>
    </div>
  </section>
</Layout>

<style>
  .filter-btn.active {
    background-color: var(--color-primary-container);
    color: var(--color-on-primary-container);
    border-color: var(--color-primary-container);
  }
</style>
